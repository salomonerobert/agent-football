# ==============================================================================
# Google Agent Development Kit Workshop - Environment Configuration
# ==============================================================================
# Copy this file to '.env' in the same directory and fill in your details:
# cp .env.example .env
# ==============================================================================
GOOGLE_GENAI_USE_VERTEXAI=true

# [REQUIRED] Your Google Cloud Project ID
# This is required to authenticate with Vertex AI.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id

# [OPTIONAL] Gemini Developer API Key
# If you prefer to use the Gemini Developer API instead of Vertex AI,
# comment out GOOGLE_CLOUD_PROJECT and set your API key here.
# GEMINI_API_KEY=your-gemini-api-key